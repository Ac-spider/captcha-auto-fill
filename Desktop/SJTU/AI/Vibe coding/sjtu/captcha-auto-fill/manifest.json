{
  "manifest_version": 3,
  "name": "验证码自动识别",
  "version": "1.0.0",
  "description": "自动检测、识别并填写网页验证码",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": [
      "lib/ocr-service.js",
      "lib/kimi-ocr.js",
      "lib/openai-ocr.js",
      "lib/claude-ocr.js",
      "lib/gemini-ocr.js",
      "lib/baidu-ocr.js",
      "lib/aliyun-ocr.js",
      "lib/captcha-recognizer.js",
      "content.js"
    ],
    "run_at": "document_end"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [{
    "resources": ["lib/*.js"],
    "matches": ["<all_urls>"]
  }],
  "commands": {
    "manual-recognize": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "手动识别当前页面验证码"
    }
  }
}
